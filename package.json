{
  "name": "code-stroll",
  "version": "0.1.0",
  "description": "Interactive code review learning sessions for opencode",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "code-stroll": "dist/cli.js"
  },
  "files": [
    "dist",
    "config"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist && bun build bin/cli.ts --outdir dist --outfile dist/cli.js --target node",
    "dev": "bun --watch src/index.ts",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "code-review",
    "learning"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bronteee/code-stroll"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.15"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/bun": "latest"
  }
}
